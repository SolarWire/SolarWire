{
  "name": "solarwire",
  "version": "1.6.1",
  "description": "SolarWire DSL - A lightweight, Markdown-style DSL for UI wireframes",
  "private": true,
  "main": "packages/core/parser/dist/index.js",
  "types": "packages/core/parser/dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./packages/core/parser/dist/index.d.ts",
      "default": "./packages/core/parser/dist/index.js"
    },
    "./parser": {
      "types": "./packages/core/parser/dist/index.d.ts",
      "default": "./packages/core/parser/dist/index.js"
    },
    "./renderer-svg": {
      "types": "./packages/core/renderer-svg/dist/index.d.ts",
      "default": "./packages/core/renderer-svg/dist/index.js"
    }
  },
  "workspaces": [
    "packages/*",
    "packages/core/*",
    "packages/apps/*",
    "packages/ai/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "test": "npm test --workspaces"
  },
  "license": "MIT",
  "author": "SolarWire",
  "repository": {
    "type": "git",
    "url": "https://github.com/SolarWire/SolarWire.git"
  },
  "keywords": [
    "solarwire",
    "wireframe",
    "dsl",
    "ui",
    "design"
  ],
  "dependencies": {
    "peggy": "^4.0.2"
  }
}
