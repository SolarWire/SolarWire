      [""] @(350,625) w=80 h=40 bg=#f1f5f9 r=6
      [""] @(450,625) w=80 h=40 bg=#f1f5f9 r=6
  {col} w=550 h=700 gap=0 bg=#ffffff
    {col} w=550 h=100 bg=#ffffff
