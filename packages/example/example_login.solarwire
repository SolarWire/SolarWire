!title="Modern Admin Login Page"
!width=1200
!height=800
!c=#333
!bg=#ffffff
!size=12
!line-height=1.5

{row} @(50,50) w=1100 h=700 gap=0
  {col} w=550 h=700 gap=0 bg=#f8fafc
    {col} w=550 h=100 bg=#ffffff
      [""] @(50,70) w=50 h=50 bg=#4f46e5 r=8
