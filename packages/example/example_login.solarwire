      "name@company.com" @(70,275) size=14 c=#9ca3af
      
      "Password" @(50,330) size=13 bold c=#374151
      [""] @(50,355) w=400 h=50 bg=#f9fafb r=8 border=1 b=#e5e7eb
      "••••••••" @(70,385) size=16 c=#1f2937
      [""] @(460,355) w=40 h=50 bg=#f3f4f6 r=8
      
      [""] @(50,430) w=18 h=18 bg=#ffffff r=4 border=1 b=#d1d5db
      "Remember me" @(80,443) size=13 c=#374151
      "Forgot password?" @(360,443) size=13 c=#4f46e5 bold
      
      ["Sign In"] @(50,480) w=450 h=55 bg=#4f46e5 r=10 c=#ffffff bold
      
