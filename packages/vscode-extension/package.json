{
  "name": "solarwire",
  "displayName": "SolarWire",
  "description": "SolarWire language support and preview",
  "version": "1.3.0",
  "publisher": "solarwire",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:markdown",
    "onLanguage:solarwire",
    "onFileSystem:*.md",
    "onFileSystem:*.solarwire",
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "files": [
    "dist/**",
    "lib/**",
    "syntaxes/**",
    "snippets/**",
    "language-configuration.json",
    "readme.md",
    "LICENSE"
  ],
  "contributes": {
    "markdown.markdownItPlugins": true,
    "commands": [
      {
        "command": "solarwire.preview",
        "title": "SolarWire: Open Preview"
      },
      {
        "command": "solarwire.exportSvg",
        "title": "SolarWire: Export SVG"
      },
      {
        "command": "solarwire.exportPng",
        "title": "SolarWire: Export PNG"
      }
    ],
    "languages": [
      {
        "id": "solarwire",
        "aliases": [
          "SolarWire",
          "solarwire"
        ],
        "extensions": [
          ".solarwire"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "solarwire",
        "scopeName": "source.solarwire",
        "path": "./syntaxes/solarwire.tmLanguage.json"
      },
      {
        "language": "markdown",
        "scopeName": "text.html.markdown",
        "path": "./syntaxes/solarwire-markdown.tmLanguage.json",
        "injectTo": ["text.html.markdown"]
      }
    ],
    "snippets": [
      {
        "language": "solarwire",
        "path": "./snippets/solarwire.json"
      }
    ]
  },
  "scripts": {
    "build": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2"
  },
  "dependencies": {
  }
}
